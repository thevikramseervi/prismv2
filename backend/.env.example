# Copy this file to .env and fill in your actual values.
# Never commit .env to git.

# Database — get from Neon dashboard
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-64-byte-random-hex-string"
JWT_EXPIRATION="7d"

# Server
PORT=3000
NODE_ENV="development"   # Use "production" on Render

# Frontend URL — used for CORS and password reset links
# Local dev: http://localhost:5173
# Production: https://your-site.netlify.app
FRONTEND_URL="http://localhost:5173"

# SMTP — for password reset emails (optional; links logged to console if not set)
# Gmail: create an App Password at Google Account > Security > 2-Step > App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@gmail.com

# Dev-only: log password reset links to console when SMTP is not configured
# Set to "true" only in local dev, never in production
# DEV_LOG_PASSWORD_RESET_LINK=false

# Biometric API (reserved for future hardware integration)
BIOMETRIC_API_URL=""
BIOMETRIC_API_KEY=""
